# ═══════════════════════════════════════════════════════════════
#  Données et modèles — montés via volumes, pas dans l'image
# ═══════════════════════════════════════════════════════════════
data/
models/

# ═══════════════════════════════════════════════════════════════
#  Python — cache inutile dans un container
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ═══════════════════════════════════════════════════════════════
#  Git — le container n'a pas besoin de l'historique
# ═══════════════════════════════════════════════════════════════
.git/
.gitignore

# ═══════════════════════════════════════════════════════════════
#  Docker — éviter la récursion (le Dockerfile dans l'image)
# ═══════════════════════════════════════════════════════════════
Dockerfile
docker-compose.yml
.dockerignore

# ═══════════════════════════════════════════════════════════════
#  IDE / OS — fichiers de config perso
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store

# ═══════════════════════════════════════════════════════════════
#  Divers
# ═══════════════════════════════════════════════════════════════
README.md
*.log